#!/usr/bin/env sh
# Build the Rust staticlib for gsemr.

# Fail on error
set -e

RUST_SRC_DIR="src/rust"

if [ ! -f "$RUST_SRC_DIR/Cargo.toml" ]; then
    echo "ERROR: Cannot find $RUST_SRC_DIR/Cargo.toml"
    exit 1
fi

# Check for cargo
if ! command -v cargo > /dev/null 2>&1; then
    echo "ERROR: cargo not found. Please install Rust: https://rustup.rs"
    exit 1
fi

# The Rust crate's Cargo.toml contains a `[patch.crates-io]` block that
# redirects the internal gsem* crates to the in-repo sources when the
# package is built from the source tree (local dev / CI). When this
# package is installed from a tarball, the relative patch paths don't
# resolve and cargo errors instead of falling back to the crates.io
# dependencies. Detect that case by probing one of the patch paths and
# strip the `[patch.crates-io]` block when it's missing, so cargo uses
# the published versions declared in [dependencies].
if [ ! -d "$RUST_SRC_DIR/../../../../crates/gsem" ]; then
    echo "Local crates/ not found; stripping [patch.crates-io] for tarball build"
    awk '
        /^\[patch\.crates-io\]/ { skip = 1; next }
        /^\[/ && skip { skip = 0 }
        !skip { print }
    ' "$RUST_SRC_DIR/Cargo.toml" > "$RUST_SRC_DIR/Cargo.toml.stripped"
    mv "$RUST_SRC_DIR/Cargo.toml.stripped" "$RUST_SRC_DIR/Cargo.toml"
fi

echo "Building Rust library..."
cd "$RUST_SRC_DIR"
cargo build --release
cd ../..

# Copy the static library
RUST_TARGET_DIR="src/rust/target/release"
if [ -f "$RUST_TARGET_DIR/libgsemr.a" ]; then
    cp "$RUST_TARGET_DIR/libgsemr.a" src/
    echo "Copied libgsemr.a to src/"
elif [ -f "$RUST_TARGET_DIR/libgsemr.dylib" ]; then
    cp "$RUST_TARGET_DIR/libgsemr.dylib" src/
    echo "Copied libgsemr.dylib to src/"
else
    echo "ERROR: Could not find compiled Rust library"
    ls -la "$RUST_TARGET_DIR"/libgsemr* 2>/dev/null || true
    exit 1
fi

echo "Rust build complete."
